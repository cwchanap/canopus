{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DaemonConfig",
  "description": "Configuration structure for the daemon",
  "type": "object",
  "required": [
    "host",
    "logLevel",
    "port"
  ],
  "properties": {
    "host": {
      "description": "Host to bind the daemon to",
      "type": "string"
    },
    "logLevel": {
      "description": "Log level for the daemon",
      "type": "string"
    },
    "maxConnections": {
      "description": "Maximum number of concurrent connections",
      "default": 100,
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "port": {
      "description": "Port to bind the daemon to",
      "type": "integer",
      "format": "uint16",
      "minimum": 0.0
    }
  }
}