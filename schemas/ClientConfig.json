{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientConfig",
  "description": "Client configuration structure",
  "type": "object",
  "required": [
    "daemonHost",
    "daemonPort"
  ],
  "properties": {
    "daemonHost": {
      "description": "Daemon host to connect to",
      "type": "string"
    },
    "daemonPort": {
      "description": "Daemon port to connect to",
      "type": "integer",
      "format": "uint16",
      "minimum": 0.0
    },
    "timeoutSeconds": {
      "description": "Connection timeout in seconds",
      "default": 30,
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    }
  }
}