{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SystemState",
  "description": "System state representation",
  "type": "object",
  "required": [
    "activeConnections",
    "daemonRunning",
    "lastUpdated",
    "uptimeSeconds",
    "version"
  ],
  "properties": {
    "activeConnections": {
      "description": "Number of active connections",
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "daemonRunning": {
      "description": "Whether the daemon is running",
      "type": "boolean"
    },
    "lastUpdated": {
      "description": "Last update timestamp",
      "type": "string"
    },
    "uptimeSeconds": {
      "description": "System uptime in seconds",
      "type": "integer",
      "format": "uint64",
      "minimum": 0.0
    },
    "version": {
      "description": "Current system version",
      "type": "string"
    }
  }
}